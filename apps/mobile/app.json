{
  "expo": {
    "name": "Borg",
    "slug": "borg",
    "version": "0.1.0",
    "scheme": "borg",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0e0c"
    },
    "ios": {
      "bundleIdentifier": "com.borg.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Borg needs camera access to capture photos for file uploads.",
        "NSPhotoLibraryUsageDescription": "Borg needs photo library access to attach images to messages.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "com.borg.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0e0c"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-haptics"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
