# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgres://borg:borg@127.0.0.1:5432/borg
WATCHED_REPOS=/path/to/repo:make test!manual|/path/to/other:cargo test

# Infrastructure (override defaults)
WEB_BIND=127.0.0.1        # default: 127.0.0.1
AUTH_MODE=local           # local | cloudflare_access
CLOUDFLARE_ACCESS_EMAIL_HEADER=cf-access-authenticated-user-email
CLOUDFLARE_ADMIN_EMAILS=you@example.com

# Initial DB seeds (edit via dashboard after first boot)
ASSISTANT_NAME=Borg
PIPELINE_REPO=/path/to/primary/repo
PIPELINE_TEST_CMD=cargo test
GIT_VIA_BORG=true
GIT_CLAUDE_COAUTHOR=false
GIT_USER_COAUTHOR=Your Name <you@example.com>

# GitHub token for pushing branches and creating PRs.
# Users can override this per-account in dashboard settings.
GITHUB_TOKEN=ghp_your_token_here

# Messaging integrations (all optional)
DISCORD_TOKEN=                # Bot token from discord.com/developers
WA_AUTH_DIR=store/wa-auth     # WhatsApp multi-file auth state directory
WA_DISABLED=false

# Slack (Socket Mode — no public URL needed)
# 1. Create an app at api.slack.com/apps
# 2. Enable Socket Mode, generate an App-Level Token (xapp-...) with connections:write
# 3. Add bot scopes: app_mentions:read, channels:history, chat:write, groups:history, im:history, mpim:history, users:read
# 4. Install to workspace and copy the Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
